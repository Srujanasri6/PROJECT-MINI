    },
    {
      "cell_type": "code",
      "source": [
        "!pip install rasterio matplotlib -q\n",
        "import rasterio, numpy as np, matplotlib.pyplot as plt"
      ],
      "metadata": {
        "id": "Vc-2rGB1S4oH"
      },
      "execution_count": 6,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "red = rasterio.open('B04.tif').read(1).astype('float32')\n",
        "nir = rasterio.open('B08.tif').read(1).astype('float32')"
      ],
      "metadata": {
        "id": "_XZnFXFUS8bB"
      },
      "execution_count": 7,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "print(\"Red min/max:\", red.min(), red.max())\n",
        "print(\"NIR min/max:\", nir.min(), nir.max())\n",
        "print(\"Are files identical?\", np.array_equal(red, nir))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "ISUKG5EVTGrD",
        "outputId": "3b4a320e-2c9a-418e-da52-c155bf2aeb51"
      },
      "execution_count": 8,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Red min/max: 2.0 18024.0\n",
            "NIR min/max: 86.0 11712.0\n",
            "Are files identical? False\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "ndvi = (nir - red) / (nir + red + 1e-10)\n",
        "ndvi = np.clip(ndvi, -1, 1)"
      ],
      "metadata": {
        "id": "U-qaCavDTNHL"
      },
      "execution_count": 9,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "healthy_pixels = np.sum(ndvi > 0.4)\n",
        "total_pixels = ndvi.size\n",
        "print(f\"Healthy crop area: {healthy_pixels/total_pixels*100:.1f}%\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "8Vtt4N1yUH-t",
